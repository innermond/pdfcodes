{
  "name": "web-preview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build .. --target web --out-dir web-preview/src/wasm --out-name pdfcodes",
    "build:wasm-svg": "wasm-pack build ../svg-wasm --target web --out-dir ../web-preview/src/wasm-svg --out-name pdfcodes_svg",
    "dev": "npm run build:wasm && npm run build:wasm-svg && vite",
    "build": "npm run build:wasm && npm run build:wasm-svg && paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy baseLocale --emit-ts-declarations && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "fonts:manifest": "node scripts/build-google-fonts-manifest.mjs",
    "build:en": "LOCALE=en npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "fflate": "^0.8.3",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.22.0",
    "@inlang/plugin-m-function-matcher": "^2.1.0",
    "@inlang/plugin-message-format": "^4.2.0",
    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}

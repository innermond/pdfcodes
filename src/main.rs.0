use printpdf::*;
use std::fs::File;
use std::io::BufWriter;
use std::env;

static MONTSERRAT_BOLD_TTF: &[u8] = include_bytes!("./assets/fonts/Montserrat-Bold.ttf");
static BKG: &[u8] = include_bytes!("./assets/img/background.png");

fn main() -> Result<(), Box<dyn std::error::Error>> {
    // Get command line arguments
    let args: Vec<String> = env::args().collect();
    
    if args.len() < 2 {
        eprintln!("Usage: {} <csv_file> <background_pdf>", args[0]);
        eprintln!("Example: {} input.csv background.pdf", args[0]);
        std::process::exit(1);
    }

    let csv_path = &args[1];
    
    // Read strings from CSV file
    let text_list = read_csv(csv_path)?;
    
    println!("Loaded {} entries from CSV", text_list.len());
    
    // Generate the PDF
    generate_pdf_with_background(&text_list, "output.pdf")?;
    
    println!("PDF generated successfully: output.pdf");
    Ok(())
}

fn read_csv(path: &str) -> Result<Vec<String>, Box<dyn std::error::Error>> {
    let file = File::open(path)?;
    let mut csv_reader = csv::Reader::from_reader(file);
    
    let mut text_list = Vec::new();
    
    // Read each record from CSV
    for result in csv_reader.records() {
        let record = result?;
        // Take the first field of each row
        if let Some(field) = record.get(0) {
            text_list.push(field.to_string());
        }
    }
    
    Ok(text_list)
}

fn generate_pdf_with_background(
    text_list: &[String],
    output_path: &str,
) -> Result<(), Box<dyn std::error::Error>> {
    let mut doc = PdfDocument::new("PDF with Background");

    let font_index = 0;
    let mut warnings = Vec::new();

    let font = ParsedFont::from_bytes(MONTSERRAT_BOLD_TTF, font_index, &mut warnings).unwrap();
    let code_font_id = doc.add_font(&font);

    let page_width = Mm(75.0);
    let page_height = Mm(50.0);

    let options = TextShapingOptions {
        font_size: Pt(10.0),
        // automatically break the text into lines on overflow
        max_width: Some(page_width.into_pt()),
        // will automatically center all lines
        align: TextAlign::Center,
        ..Default::default()
    };

    let shaped_origin = Point {x: Pt(0.0), y: Mm(15.3).into()};

    // Load an image
    let image = RawImage::decode_from_bytes(BKG, &mut Vec::new()).unwrap();
    let image_id = doc.add_image(&image);

    // Create pages for each text entry
    let mut pages = Vec::new();
    
    for text in text_list {
        let code_font_id = code_font_id.clone();
        let shaped_text = doc.shape_text(text, &code_font_id, &options).unwrap();
        let shaped_ops = shaped_text.get_ops(shaped_origin);

        // Add background
        let mut page_contents = vec![
            Op::UseXobject {
                id: image_id.clone(),
                transform: XObjectTransform::default(),
            },
        ];
        page_contents.extend(shaped_ops);
        
        let page = PdfPage::new(page_width, page_height, page_contents);
        pages.push(page);
    }
    
    // Add pages to document and save
    doc.with_pages(pages);
    
    let file = File::create(output_path)?;
    let mut writer = BufWriter::new(file);
    let save_options = PdfSaveOptions {
        optimize: true,
        subset_fonts: true,
        ..PdfSaveOptions::default()
    };
    doc.save_writer(&mut writer, &save_options, &mut warnings);
    
    if !warnings.is_empty() {
        eprintln!("Warnings during PDF generation:");
        for warning in warnings {
            eprintln!("  - {}", warning.msg);
        }
    }
    
    Ok(())
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_csv_reading() {
        let text_list = vec!["Test Page 1".to_string(), "Test Page 2".to_string()];
        assert_eq!(text_list.len(), 2);
    }
}
